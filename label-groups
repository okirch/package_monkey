#!/usr/bin/python3

forceRefresh = True

from repos import RepoDict, UrlCacheStrategy
from products import ProductCatalog, CacheLocation
from packages import Product, Resolver, ResolverWorker, ResolverPreferences, PackageSelector, PackageCollection
from filter import PackageFilter, Classification
from options import Application

application = Application('build-dependency-tree')
dummy = application.catalog

store = application.backingStore
store.enableDependencyTreeLookups()
store.enableSourceLookups()

classificationScheme = Classification.Scheme()
packageFilter = PackageFilter(scheme = classificationScheme)
unclassified = packageFilter.makeGroup("Unclassified", Classification.TYPE_BINARY)

packageSelector = PackageSelector()
collection = PackageCollection()

resolver = Resolver(backingStore = store)

for pinfo in store.enumerateLatestPackages():
	pkg = store.retrievePackage(pinfo)

	verdict = packageFilter.apply(pkg, pinfo.product)
	if verdict is not None:
		verdict.labelPackage(pkg)
	else:
		# we currently have no good way to properly mark unclassified packages
		# group = unclassified
		pass

	collection.add(pkg)

def flattenLabelTree(label, alreadySeen):
	alreadySeen.add(label)
	result = []

	if label.type == Classification.TYPE_BINARY:
		children = label.uses
	else:
		children = label.buildRequires

	for child in children:
		if child not in alreadySeen:
			result += flattenLabelTree(child, alreadySeen)

	result.append(label)
	return result

def flattenGroup(groupName, alreadySeen):
	group = packageFilter.makeGroup(groupName)
	label = group.label

	if label in alreadySeen:
		return set()

	result = flattenLabelTree(label, alreadySeen)

	for flavor in group.flavors:
		label = flavor.label
		if label not in alreadySeen:
			result += flattenLabelTree(label, alreadySeen)

	return result

def flattenGroupList(*names):
	labelSequence = []
	alreadySeen = set()
	for groupName in names:
		labelSequence += flattenGroup(groupName, alreadySeen)
	return labelSequence

binaryLabels = flattenGroupList("@Core", "@HostCore", "@Kernel", "@UpdateStack", "@CoreLibraries+odbc", "@MinimalSystemd")
sourceLabels = flattenGroupList("Core", "KernelPlus")

worker = ResolverWorker(resolver)
problemLog = worker.problems

productArchitecture = store.getProperty("arch")
if productArchitecture is None:
	raise Exception("database does not record architecture of original query")

resolverContext = worker.contextForArch(productArchitecture)
preferences = ResolverPreferences()

closure = {}
for label in binaryLabels:
	group = packageFilter.makeGroup(label.name)
	labelledPackages = group.packages

	print(f"Classify packages belonging to {group.label}")

	# Step 1: build the runtime dependency closure
	classifier = Classification.DownwardClosure(worker, productArchitecture, preferences, label)
	classifier.classify(labelledPackages)
	labelledPackages = classifier.result

	# FIXME:
	# Maybe we should do this the other way round and assign all flavor packages
	# to the group flavor of a sibling as soon as we have that one labelled
	classifier = Classification.AutoflavorPackageClosure(problemLog, store)
	classifier.classify(labelledPackages)
	for flavorDef in packageFilter.autoFlavors:
		found = classifier.getFlavor(flavorDef.name)
		if found is None:
			continue

		flavor = packageFilter.instantiateAutoFlavor(group, flavorDef)
		relabeled = classifier.labelFlavoredPackages(flavorDef.name, flavor.label)
		closure[flavor.name] = relabeled

	# Step N: sort all other sibling packages into $Group-unused
	siblingGroup = packageFilter.makeFlavorGroup(group, "unused")
	classifier = Classification.SiblingPackageClosure(problemLog, siblingGroup.label, store)
	classifier.classify(labelledPackages)
	closure[siblingGroup.name] = classifier.result

	closure[label.name] = labelledPackages

for label in sourceLabels:
	group = packageFilter.makeSourceGroup(label.name)

	print(f"Classify packages belonging to {group.label}")

	classifier = Classification.BuildRequireClosure(worker, productArchitecture, preferences, label)
	assert(classifier)
	for component in label.buildRequires:
		componentGroup = packageFilter.makeGroup(component.name)
		assert(componentGroup)
		classifier.classify(componentGroup.packages)

	closure[label.name] = classifier.result

for label in binaryLabels:
	print()
	print(label)

	for pkg in sorted(closure[label.name], key = lambda p: p.name):
		print(f"  {pkg.name}")

for label in sourceLabels:
	print()
	print(f"Source project {label}")

	for pkg in sorted(closure[label.name], key = lambda p: p.name):
		print(f"  {pkg.name}")

if problemLog:
	print()
	print("==================================================================")
	print("The resolver flagged the following problems")
	problemLog.show()
