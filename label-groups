#!/usr/bin/python3

forceRefresh = True

from repos import RepoDict, UrlCacheStrategy
from products import ProductCatalog, CacheLocation
from packages import Product, Resolver, ResolverWorker, ResolverPreferences, PackageSelector, PackageCollection
from filter import PackageFilter, Classification
from options import Application

application = Application('build-dependency-tree')
dummy = application.catalog

store = application.backingStore
store.enableDependencyTreeLookups()
store.enableSourceLookups()

classificationScheme = Classification.Scheme()
packageFilter = PackageFilter(scheme = classificationScheme)
unclassified = packageFilter.makeGroup("Unclassified")

packageSelector = PackageSelector()
collection = PackageCollection()

resolver = Resolver(backingStore = store)
for pinfo in store.enumerateLatestPackages():
	pkg = store.retrievePackage(pinfo)

	verdict = packageFilter.apply(pkg, pinfo.product)
	if verdict is not None:
		verdict.labelPackage(pkg)
		group = verdict.group
	else:
		group = unclassified

	collection.add(pkg)

def flattenLabelTree(label, alreadySeen):
	alreadySeen.add(label)
	result = []

	for child in label.uses:
		if child not in alreadySeen:
			result += flattenLabelTree(child, alreadySeen)

	result.append(label)
	return result

def flattenGroup(groupName, alreadySeen):
	group = packageFilter.makeGroup(groupName)
	label = group.label

	assert(label not in alreadySeen)
	return flattenLabelTree(label, alreadySeen)

def flattenGroupList(*names):
	labelSequence = []
	alreadySeen = set()
	for groupName in names:
		labelSequence += flattenGroup(groupName, alreadySeen)
	return labelSequence

binaryLabels = flattenGroupList("@Core", "@HostCore", "@Kernel", "@UpdateStack")
sourceLabels = flattenGroupList("Core", "KernelPlus")

worker = ResolverWorker(resolver)

class Inventory(dict):
	def update(self, packages):
		for pkg in packages:
			self.add(pkg)

	def add(self, pkg):
		assert(pkg.backingStoreId)

		id = pkg.backingStoreId
		conflict = self.get(id)
		if conflict is not None and conflict is not pkg:
			print(f"Duplicate package objects for pkgId {id}")
			print(f"  - {pkg} {pkg.fullname()}")
			print(f"  - {conflict} {conflict.fullname()}")
		else:
			self[id] = pkg

inventory = Inventory()

resolverContext = worker.contextForArch(collection.uniqueArch)
preferences = ResolverPreferences()

closure = {}
for label in binaryLabels:
	group = packageFilter.makeGroup(label.name)

	print(f"Classify packages belonging to {group.label}")
	classifier = Classification.DownwardClosure(worker, collection.uniqueArch, preferences, label)
	classifier.classify(group.packages)

	closure[label.name] = classifier.result

	inventory.update(group.packages)
	inventory.update(classifier.result)

for label in sourceLabels:
	group = packageFilter.makeSourceGroup(label.name)

	print(f"Classify packages belonging to {group.label}")

	classifier = Classification.BuildRequireClosure(worker, collection.uniqueArch, preferences, label)
	assert(classifier)
	for component in label.builds:
		componentGroup = packageFilter.makeGroup(component.name)
		assert(componentGroup)
		classifier.classify(componentGroup.packages)

	closure[label.name] = classifier.result

for label in binaryLabels:
	print()
	print(label)

	for pkg in sorted(closure[label.name], key = lambda p: p.name):
		print(f"  {pkg.name}")

for label in sourceLabels:
	print()
	print(f"Source project {label}")

	for pkg in sorted(closure[label.name], key = lambda p: p.name):
		print(f"  {pkg.name}")

if worker.problems:
	print()
	print("==================================================================")
	print("The resolver flagged the following problems")
	worker.problems.show()
