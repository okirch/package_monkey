class LabelTreeTraversal:
	def __init__(self):
		self.alreadySeen = set()
		self.visited = []

	def flatten(self, label):
		return self.flattenWork(label, lambda l: l.uses)

	def flattenBuildRequirements(self, label):
		return self.flattenWork(label, lambda l: l.buildRequires)

	def flattenWork(self, label, childAccessor):
		result = []

		if label in self.alreadySeen:
			return result

		self.alreadySeen.add(label)
		for child in childAccessor(label):
			if child not in self.alreadySeen:
				result += self.flattenWork(child, childAccessor)

		self.visited.append(label)
		result.append(label)

		for child in label.flavors:
			result += self.flattenWork(child, childAccessor)

		return result

	def __iter__(self):
		return iter(self.visited)

def flattenGroupList(*names):
	traversal = LabelTreeTraversal()
	for groupName in names:
		group = packageFilter.makeGroup(groupName)
		traversal.flatten(group.label)
	return traversal

binaryTraversal = flattenGroupList("@Core", "@HostCore", "@Kernel", "@UpdateStack", "@CoreLibraries+odbc", "@MinimalSystemd")
#sourceTraversal = flattenGroupList("Core", "KernelPlus")
sourceTraversal = []

worker = ResolverWorker(resolver)
problemLog = worker.problems

productArchitecture = store.getProperty("arch")
if productArchitecture is None:
	raise Exception("database does not record architecture of original query")

resolverContext = worker.contextForArch(productArchitecture)
preferences = ResolverPreferences()

def classifyRuntimeDependencies(label):
	global closure

	group = packageFilter.makeGroup(label.name)
	labelledPackages = group.packages

	print(f"Classify packages belonging to {group.label}")

	# Step 1: build the runtime dependency closure
	classifier = Classification.DownwardClosure(worker, productArchitecture, preferences, label)
	classifier.classify(labelledPackages)
	labelledPackages = classifier.result
	closure[label.name] = labelledPackages

	classifier = Classification.AutoflavorPackageClosure(problemLog, store)
	classifier.classify(labelledPackages)
	for flavorDef in packageFilter.autoFlavors:
		found = classifier.getFlavor(flavorDef.name)
		if found is None:
			continue

		flavor = packageFilter.instantiateAutoFlavor(group, flavorDef)
		relabeled = classifier.labelFlavoredPackages(flavorDef.name, flavor.label)
		closure[flavor.name] = relabeled

	# Step N: sort all other sibling packages into $Group+unused.
	# To avoid infinite recursion, do not perform this step for the +unused flavor itself.
	if not label.name.endswith("unused"):
		siblingGroup = packageFilter.makeFlavorGroup(group, "unused")
		classifier = Classification.SiblingPackageClosure(problemLog, siblingGroup.label, store)
		classifier.classify(labelledPackages)
		closure[siblingGroup.name] = classifier.result

def classifyBuildDependencies(label):
	global binaryTraversal
	global closure

	# get the build requirements of this label and make sure we've satisfied all their runtime
	# requirements
	for buildLabel in binaryTraversal.flattenBuildRequirements(label):
		classifyRuntimeDependencies(buildLabel)

	group = packageFilter.makeGroup(label.name)

	classifier = Classification.BuildRequiresClosure(problemLog, label, store)
	packagesNeededForBuild = classifier.classify(group.packages)

	unlabelledPackages = classifier.unlabelledPackages
	if unlabelledPackages:
		print(f"{label.name} has {len(unlabelledPackages)} unclassified build requirements")

		print(f"Classifying new build requirements for {label}")
		classifier = Classification.UnknownPackageClassifier(worker, productArchitecture, preferences, label)
		classifier.classify(unlabelledPackages)

		# FIXME: This should also be part of the problem report
		for suggestedLabel, candidatePackages in classifier.suggestions:
			print(f"   Classifier suggests label {suggestedLabel} for these package(s)")
			for cand in candidatePackages:
				print(f"      {cand.shortname}")

closure = {}
processedBinaryLabels = []

queue = list(binaryTraversal)
while queue:
	label = queue.pop(0)
	classifyRuntimeDependencies(label)

	# After classification, new flavors may have been added automatically
	# Traverse any newly created flavors insert them at the head of the queue
	for flavor in label.flavors:
		queue[:0] = binaryTraversal.flatten(flavor)

for label in binaryTraversal:
	classifyBuildDependencies(label)

for label in sourceTraversal:
	group = packageFilter.makeSourceGroup(label.name)

	print(f"Classify packages belonging to source project {group.label}")

	classifier = Classification.BuildRequireClosure(worker, productArchitecture, preferences, label)
	assert(classifier)
	for component in label.buildRequires:
		componentGroup = packageFilter.makeGroup(component.name)
		assert(componentGroup)
		classifier.classify(componentGroup.packages)

	closure[label.name] = classifier.result

for label in binaryTraversal:
	print()
	print(label)

	for pkg in sorted(closure[label.name], key = lambda p: p.name):
		print(f"  {pkg.name}")

for label in sourceTraversal:
	print()
	print(f"Source project {label}")

	for pkg in sorted(closure[label.name], key = lambda p: p.name):
		print(f"  {pkg.name}")

