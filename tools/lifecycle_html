#!/usr/bin/python3
##################################################################
#
# Load the life cycle yaml files generated by compose, and
# dump them into an html file.
#
# This tool can be used standalone without any of the package monkey
# support stuff installed. You can call it directly from your
# cloned package_monkey repository:
#
#   tools/lifecycle_html somepath/lifecycle_sles_16.1.yaml
#
# You can also invoke it with just a directory name; it will then
# scan the directory for valid lifecycle data files and convert
# each of them to HTML in turn.
#
#   tools/lifecycle_html ~/.local/package_monkey/sle16.1
#
# TODO: add localization support
#
##################################################################

import sys
import os
import yaml
import argparse

class ProductLifecycle(object):
	class Lifecycle(object):
		def __init__(self, id):
			self.id = id
			self.name = id
			self.description = None
			self.mode = None
			self.stability = None
			self.releaseData = None
			self.cadence = None
			self.rpms = []
			self.implementations = []

		def __str__(self):
			return self.name

	def __init__(self):
		self.id = None
		self.productName = None
		self.defaultLifecycle = None
		self._lifecycles = {}

	@property
	def lifecycles(self):
		for id, lifecycle in sorted(self._lifecycles.items()):
			yield lifecycle

	def createLifecycle(self, id):
		lifecycle = self._lifecycles.get(id)
		if lifecycle is None:
			lifecycle = self.Lifecycle(id)
			self._lifecycles[id] = lifecycle
		return lifecycle

	def getLifecycle(self, id):
		return self._lifecycles.get(id)

	def trimVersions(self, lifecycle):
		# Trim down .implementations to the list of versions actually shipped
		resolved = []
		for id in lifecycle.implementations:
			impl = self.getLifecycle(id)
			if impl is None:
				continue
			if impl.description is None:
				impl.description = f"(Implementation of life cycle {lifecycle.name})"
			resolved.append(id)
		lifecycle.implementations = resolved

	def render(self, formatter):
		formatter.caption(f"Lifecycles for {self.productName}")
		formatter.beginTable()
		defaultLifecycle = self.getLifecycle(self.defaultLifecycle)
		if defaultLifecycle is not None:
			formatter.emitDefaultLifecycle(defaultLifecycle)

		for lifecycle in self.lifecycles:
			if lifecycle is defaultLifecycle:
				continue
			if lifecycle.mode == 'versioned' and not lifecycle.implementations:
				continue
			formatter.emitLifecycle(lifecycle)
		formatter.endTable()

	def extractStrings(self, formatter):
		formatter.emitComment(f'Product {self.id}')
		if self.productName:
			formatter.emitString(self.productName, reference = 'product-display-name')

		for lifecycle in self.lifecycles:
			formatter.emitComment(f'Life cycle {lifecycle}')
			formatter.emitString(lifecycle.name, reference = f'{lifecycle.id}/display-name')
			formatter.emitMultilineString(lifecycle.description, reference = f'{lifecycle.id}/description')

class LifecycleDataLoader(object):
	def __init__(self, path):
		self.path = path
		self.defaultEOL = {}

	def load(self):
		product = ProductLifecycle()

		print(f"Processing {self.path}")
		with open(self.path) as f:
			data = yaml.full_load(f)

		self.extractMetadata(product, data)

		# Extract the default LC first
		lcdata = data.pop(product.defaultLifecycle, None)
		if lcdata is not None:
			lifecycle = product.createLifecycle(product.defaultLifecycle)
			self.extractLifecycle(lifecycle, lcdata)

			self.defaultEOL['general'] = lifecycle.eolGeneral
			self.defaultEOL['lts'] = lifecycle.eolLTS

		for id, lcdata in data.items():
			lifecycle = product.createLifecycle(id)
			self.extractLifecycle(lifecycle, lcdata)

		for lifecycle in product.lifecycles:
			if lifecycle.mode == 'versioned':
				product.trimVersions(lifecycle)

		return product

	def extractMetadata(self, product, data):
		info = data.pop('__info__', None)
		if info is None:
			return

		product.defaultLifecycle = info.get('default_lifecycle')
		productData = info.get('product')
		if productData is None:
			return

		product.id = productData.get('id')

		product.productName = productData.get('display_name')
		if product.productName is None:
			product.productName = productData.get('name')
		if product.productName is None:
			product.productName = product.id

	def extractLifecycle(self, lifecycle, data):
		for key, value in data.items():
			if type(value) in (int, bool):
				value = str(value)

			if key == 'display_name':
				lifecycle.name = value
			elif key == 'description':
				lifecycle.description = value
			elif key == 'mode':
				lifecycle.mode = value
			elif key == 'stability':
				lifecycle.stability = value
			elif key == 'release':
				lifecycle.release = value
			elif key == 'cadence':
				lifecycle.cadence = value
			elif key == 'roadmap':
				# for cadence=ticktock, the roadmap contains next_tick_release, next_tock_release
				pass
			elif key == 'general':
				lifecycle.eolGeneral = self.extractEOL(id, value, self.defaultEOL.get(key))
			elif key == 'lts':
				lifecycle.eolLTS = self.extractEOL(id, value, self.defaultEOL.get(key))
			elif key == 'implementations':
				lifecycle.implementations = value
			elif key == 'rpms':
				lifecycle.rpms = value
			else:
				raise Exception(f"{self.path}: unexpected element \"{key}\" in lifecycle {id}")

	def extractEOL(self, id, contract, defaultEOL = None):
		eol = defaultEOL
		for key, value in contract.items():
			if key == 'supported':
				value = str(value)
				if value.lower() in ('no', 'false'):
					return None
			elif key == 'end':
				eol = str(value)
			else:
				raise Exception(f"{self.path}: unexpected contract element \"{key}\" in lifecycle {id}")

		if eol and eol == defaultEOL:
			eol = f'={eol}'
		return eol

class LifecycleHTMLTableFormatter(object):
	def __init__(self, fp):
		self.f = fp
		self.inRow = False

	def out(self, msg):
		print(msg, file = self.f)

	def begin(self):
		self.out(HEADER)

	def end(self):
		# close any open row
		self.endRow()
		self.out(TRAILER)

	def beginRow(self):
		self.endRow()
		self.out(" <tr>")
		self.inRow = True

	def endRow(self):
		if self.inRow:
			self.inRow = False
			self.out(" </tr>")

	def captionRowSpan(self, caption):
		self.beginRow()
		self.out(f"  <td colspan=\"6\" align=\"center\" style=\"font-weight:bold;font-size:x-large\">{caption}</td>")
		self.endRow()

	def caption(self, caption):
		self.out(f"<h1>{caption}</h1>")

	def beginTable(self):
		self.out(TABLE_HEADER)

	def endTable(self):
		self.out(TABLE_TRAILER)

	def _element(self, tag, **attrs):
		if not attrs:
			return f"<{tag}>"

		alist = []
		for key, value in attrs.items():
			if value is not None:
				key = key.replace('_', '-')
				alist.append(f'{key}="{value}"')
		return f"<{tag} {' '.join(sorted(alist))}>"

	def beginElement(self, tag, **attrs):
		etag = self._element(tag, **attrs)
		self.out(f"  {etag}")

	def emitElement(self, tag, text, **attrs):
		etag = self._element(tag, **attrs)
		self.out(f"  {etag}{text}</{tag}>")

	def emitCell(self, value, valign = 'top', **attrs):
		if valign:
			attrs['valign'] = valign

		# force conversion to str, just in case:
		if value is None:
			value = ""
		else:
			value = str(value)
		if '\n' in value:
			self.beginElement('td', **attrs)
			self.emitPoorMansMarkdown(value.split('\n'))
			self.out("  </td>")
		else:
			self.emitElement('td', value, **attrs)

	def emitEOL(self, date):
		if date and date.startswith('='):
			# this EOL date aligns with the product defaults; so render it as gray
			self.emitCell(date[1:], align = 'right', style = 'color:gray')
		else:
			self.emitCell(date or "unsupported", align = 'right', style = 'font-weight:bolder')

	def emitRpmList(self, rpms):
		if not rpms:
			self.emitCell("")
			return

		rpms = sorted(map(str, rpms))
		text = '\n'.join(rpms)

		self.out(RPMCELL.replace('%%RPMS%%', text))

	def emitDefaultLifecycle(self, lifecycle):
		self.beginRow()
		self.emitCell(lifecycle.name)
		self.emitCell(lifecycle.mode, align = 'right')
		self.emitEOL(lifecycle.eolGeneral)
		self.emitEOL(lifecycle.eolLTS)
		self.emitCell(lifecycle.description + "\n\nThis is the product's default life cycle.")
		self.emitCell("RPMs not explicitly mentioned by other life cycles fall in this category.")
		self.endRow()

	def emitLifecycle(self, lifecycle):
		self.beginRow()
		self.emitCell(lifecycle.name)
		self.emitCell(lifecycle.mode, align = 'right')
		self.emitEOL(lifecycle.eolGeneral)
		self.emitEOL(lifecycle.eolLTS)
		self.emitCell(lifecycle.description)
		self.emitRpmList(lifecycle.rpms)
		self.endRow()

	def emitPoorMansMarkdown(self, lines):
		self.out('    <p>')
		inUL = False
		for line in lines:
			strippedText = line.strip()

			if strippedText.startswith('*'):
				if not inUL:
					self.out('    </p><p><ul>')
				else:
					self.out('     </li>')
				strippedText = strippedText[1:].strip()
				self.out(f'     <li>{strippedText}')
				inUL = True
				continue

			if not strippedText:
				if inUL:
					self.out('    </li></ul>')
					inUL = False
				self.out('    </p><p>')
			else:
				self.out(f"     {line}")

		if inUL:
			self.out('  </li></ul>')
			inUL = False


		self.out('    </p>')

class PoFileFormatter(object):
	def __init__(self, f):
		self.fp = f

	def out(self, msg):
		print(msg, file = self.fp)

	def begin(self):
		pass

	def end(self):
		pass

	def emitComment(self, msg):
		if not msg:
			return

		self.out('')
		self.out(f'# {msg}')

	def emitString(self, msg, reference = None):
		if not msg:
			return

		if '\n' in msg:
			self.emitMultilineString(msg, reference = reference)
			return

		assert(reference)
		self.out(f'#: {reference}')
		self.out(f'msgid "{reference}"')
		self.out(f'msgstr "{msg}"')

	def emitMultilineString(self, msg, reference = None):
		if not msg:
			return

		assert(reference)
		self.out(f'#: {reference}')

		msg = msg.replace('"', '\\"').strip()
		if '\n' in msg:
			paraID = 1
			self.out(f'msgid "{reference}/{paraID}"')
			self.out(f'msgstr ""')

			para = False
			for line in msg.split('\n'):
				line = line.strip()
				if not line:
					para = True
				else:
					if para:
						self.out('')
						paraID += 1
						self.out(f'msgid "{reference}/{paraID}"')
						self.out(f'msgstr ""')
						para = False
					self.out(f'"{line}"')
		else:
			self.out(f'msgid "{reference}/1"')
			self.out(f'msgstr "{msg}"')

