##################################################################
# process one input file
##################################################################
def openOutput(product, inputPath, outputPath, template):
	if outputPath is None:
		if product.id is None:
			print(f"Error: {inputPath}: Cannot derive output path; no product id in metadata")
			exit(1)

		assert('%ID%' in template)

		dirPath = os.path.dirname(inputPath)
		outputPath = f"{dirPath}/{template}".replace('%ID%', product.id)

	if outputPath == "-":
		print(f"  {product.productName}: writing to stdout")
		f = sys.stdout
	else:
		print(f"  {product.productName}: writing to {outputPath}")
		f = open(outputPath, "w")
	return f

def processProduct(inputPath, outputPath):
	loader = LifecycleDataLoader(inputPath)
	product = loader.load()

	f = openOutput(product, inputPath, outputPath, 'lifecycle-%ID%.html')

	formatter = LifecycleHTMLTableFormatter(f)

	formatter.begin()
	product.render(formatter)
	formatter.end()

def createPoFile(inputPath, outputPath):
	loader = LifecycleDataLoader(inputPath)
	product = loader.load()

	f = openOutput(product, inputPath, outputPath, 'lifecycle-%ID%.po')

	formatter = PoFileFormatter(f)

	formatter.begin()
	product.extractStrings(formatter)
	formatter.end()

def scanForProducts(dirPath):
	nfound = 0
	for de in os.scandir(dirPath):
		if de.is_file() and \
		   de.name.startswith('lifecycle-') and \
		   de.name.endswith('.yaml'):
			nfound += 1
			yield de.path

	if not nfound:
		print(f"{dirPath}: no life cycle definitions found")

def processArguments():
	args = argparse.ArgumentParser(os.path.basename(sys.argv[0]))

	args.add_argument('--output',
			help = 'Specify the path of the output file. \"-\" means standard output')
	args.add_argument('--create-pofile', action = 'store_true',
			help = 'Create a .po file for translators')
	args.add_argument('input', nargs = '+',
			help = 'One or more lifecycle yaml files produced by the composer, or directories containing such')

	return args.parse_args()

##################################################################
# main()
##################################################################
if __name__ == '__main__':
	opts = processArguments()

	inputs = []
	for path in opts.input:
		if os.path.isfile(path):
			inputs.append(path)
		elif os.path.isdir(path):
			print(f'Expanding {path}')
			for expanded in scanForProducts(path):
				print(f' - {expanded}')
				inputs.append(expanded)
		else:
			print(f"Error: invalid input path {path}; must be a file or directory")
			exit(1)

	if len(inputs) > 1 and opts.output and opts.output != "-":
		print(f"Error: found {len(inputs)} input files is a directory; cannot handle output {opts.output}")
		exit(1)

	if opts.create_pofile:
		for path in inputs:
			createPoFile(path, opts.output)
	else:
		for path in inputs:
			processProduct(path, opts.output)

